# Required for production usage when PII_REDACTOR_REQUIRE_API_KEY=true
PII_REDACTOR_API_KEY=change-me

# Optional: use hash comparison instead of raw key.
# Example: echo -n "change-me" | shasum -a 256
PII_REDACTOR_API_KEY_SHA256=

PII_REDACTOR_REQUIRE_API_KEY=true
PII_REDACTOR_LOG_LEVEL=INFO
PII_REDACTOR_FAIL_CLOSED_DEFAULT=true
PII_REDACTOR_ALLOW_RAW_REPLACEMENTS=false

# Detector toggles
PII_REDACTOR_USE_PRESIDIO=true
PII_REDACTOR_USE_GLINER=true

# GLiNER model/runtime options
PII_REDACTOR_GLINER_MODEL=urchade/gliner_multi_pii-v1
PII_REDACTOR_GLINER_THRESHOLD=0.75
PII_REDACTOR_GLINER_LABELS=name,first name,last name,full name

# Optional non-name tuning terms (comma-separated) and/or JSON tree path.
# Terms from these sources are treated as "not a person name" unless strong name cues exist.
PII_REDACTOR_NON_NAME_TERMS=
PII_REDACTOR_NON_NAME_TERMS_JSON_PATH=

# Runtime vault lifecycle
PII_REDACTOR_VAULT_TTL_SECONDS=3600
PII_REDACTOR_MAX_ACTIVE_SCOPES=15

# Persistence mode selector:
# - none: in-memory only
# - internal: redactor owns persistence config (e.g. supabase)
# - external: host app injects or provides external store factory
PII_REDACTOR_PERSISTENCE_MODE=none
PII_REDACTOR_REQUIRE_PERSISTENCE=false
PII_REDACTOR_INTERNAL_STORE_IMPL=supabase
PII_REDACTOR_EXTERNAL_STORE_FACTORY=

# Internal Supabase settings (required when mode=internal and impl=supabase)
PII_REDACTOR_SUPABASE_URL=
PII_REDACTOR_SUPABASE_SERVICE_ROLE_KEY=
PII_REDACTOR_SUPABASE_TABLE=pii_vault_snapshots

# Master key for encrypted persisted payloads (required when mode=internal and impl=supabase)
# Use a long random string. Rotate with PII_REDACTOR_PERSISTENCE_KEY_VERSION.
PII_REDACTOR_PERSISTENCE_MASTER_KEY=

# Persistence write-behind behavior
PII_REDACTOR_PERSISTENCE_QUEUE_MAX=1024
PII_REDACTOR_PERSISTENCE_BLOCK_ON_ERROR=true
PII_REDACTOR_PERSISTENCE_KEY_VERSION=v1
