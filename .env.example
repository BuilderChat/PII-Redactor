# Required for production usage when PII_REDACTOR_REQUIRE_API_KEY=true
PII_REDACTOR_API_KEY=change-me

# Optional: use hash comparison instead of raw key.
# Example: echo -n "change-me" | shasum -a 256
PII_REDACTOR_API_KEY_SHA256=

PII_REDACTOR_REQUIRE_API_KEY=true
PII_REDACTOR_LOG_LEVEL=INFO

# Detector toggles
PII_REDACTOR_USE_PRESIDIO=true
PII_REDACTOR_USE_GLINER=true

# GLiNER model/runtime options
PII_REDACTOR_GLINER_MODEL=urchade/gliner_multi_pii-v1
PII_REDACTOR_GLINER_THRESHOLD=0.6
PII_REDACTOR_GLINER_LABELS=person,name,first name,last name,full name
